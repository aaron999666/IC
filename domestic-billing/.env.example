HOST=0.0.0.0
PORT=8788
MAIN_SITE_PUBLIC_URL=https://iccorehub.com
MAIN_SITE_CALLBACK_URL=https://iccorehub.com/api/billing/callback
BILLING_PORTAL_PUBLIC_URL=https://pay.iccorehub.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
BILLING_WEBHOOK_SECRET=shared-secret-between-main-site-and-domestic-pay-server
DOMESTIC_GATEWAY_SECRET=internal-secret-for-local-gateway-adapter
BILLING_ENABLE_MOCK_PAYMENT=false
ALIPAY_APP_ID=2021xxxxxxxxxxxx
ALIPAY_MODE=public_key
ALIPAY_PRIVATE_KEY_PATH=/etc/iccorehub/alipay/app-private-key.pem
ALIPAY_PUBLIC_KEY_PATH=/etc/iccorehub/alipay/alipay-public-key.pem
ALIPAY_KEY_TYPE=PKCS1
ALIPAY_NOTIFY_URL=https://pay.iccorehub.com/gateway/alipay/notify
ALIPAY_GATEWAY_ENDPOINT=https://openapi.alipay.com
# Certificate mode alternative:
# ALIPAY_MODE=cert
# ALIPAY_APP_CERT_PATH=/etc/iccorehub/alipay/appCertPublicKey.crt
# ALIPAY_ALIPAY_PUBLIC_CERT_PATH=/etc/iccorehub/alipay/alipayCertPublicKey_RSA2.crt
# ALIPAY_ALIPAY_ROOT_CERT_PATH=/etc/iccorehub/alipay/alipayRootCert.crt
